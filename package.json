{
  "name": "infinite-canvas-mvp",
  "private": true,
  "version": "0.2.13",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "electron:dev": "node ./scripts/electron-dev.mjs",
    "build": "tsc -b && vite build",
    "desktop:build": "npm run build && electron-builder --linux AppImage --publish=never",
    "desktop:dir": "npm run build && electron-builder --linux dir --publish=never",
    "desktop:win": "npm run build && electron-builder --win portable --publish=never",
    "exe": "npm run desktop:win",
    "exe:fast": "vite build && electron-builder --win portable --publish=never",
    "release:patch": "npm version patch --no-git-tag-version && npm run desktop:win",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tiptap/extension-highlight": "^3.22.4",
    "@tiptap/extension-text-style": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "cytoscape": "^3.33.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "30.5.1",
    "electron-builder": "24.13.3",
    "typescript": "^5.7.3",
    "vite": "^6.2.0",
    "vitest": "^2.1.9"
  },
  "build": {
    "appId": "local.infinite-canvas-mvp",
    "productName": "Infinite Canvas",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Office"
    },
    "win": {
      "target": [
        "portable"
      ],
      "icon": null
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    }
  }
}
