{
  "name": "infinite-canvas-mvp",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "desktop:build": "npm run build && electron-builder --linux AppImage --publish=never",
    "desktop:dir": "npm run build && electron-builder --linux dir --publish=never",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/node": "^22.13.10",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "30.5.1",
    "electron-builder": "24.13.3",
    "typescript": "^5.7.3",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "local.infinite-canvas-mvp",
    "productName": "Infinite Canvas",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Office"
    }
  }
}
